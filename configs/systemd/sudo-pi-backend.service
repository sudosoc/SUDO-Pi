[Unit]
Description=SUDO-Pi Backend API (FastAPI + Uvicorn)
After=network.target
Wants=network.target

[Service]
Type=exec
User=sudo-pi
Group=sudo-pi
WorkingDirectory=/opt/sudo-pi/backend
EnvironmentFile=/opt/sudo-pi/backend/.env
ExecStart=/opt/sudo-pi/venv/bin/uvicorn app.main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --workers 1 \
    --loop uvloop \
    --no-access-log

Restart=on-failure
RestartSec=5s
StartLimitInterval=60s
StartLimitBurst=5

# Grant specific ambient capabilities to the service process itself
# (inherited by Python I/O for file manager reads/writes and network ops).
# CapabilityBoundingSet is intentionally left at the system default (all caps)
# so that SUID binaries like sudo can still acquire CAP_SETUID/CAP_SETGID
# and switch to root — a restricted bounding set would silently break sudo.
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_SYS_NICE CAP_DAC_READ_SEARCH CAP_DAC_OVERRIDE

StandardOutput=journal
StandardError=journal
SyslogIdentifier=sudo-pi-backend

[Install]
WantedBy=multi-user.target
