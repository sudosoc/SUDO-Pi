# SUDO-Pi Environment Configuration
# Copy this file to .env and adjust values before running:
#   cp .env.example .env

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=SUDO-Pi
APP_VERSION=1.0.0
APP_ENV=production       # development | production
DEBUG=false

# ─── Security ────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_-hex_32

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── Database ────────────────────────────────────────────────────────────────
# Production absolute path (set automatically by install.sh):
DATABASE_URL=sqlite+aiosqlite:////opt/sudo-pi/backend/sudo_pi.db
# Development (relative to backend/ working directory):
# DATABASE_URL=sqlite+aiosqlite:///./data/sudo_pi.db

# ─── Default Admin Credentials (change immediately after first login) ─────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@pi.local

# ─── Network Interfaces ───────────────────────────────────────────────────────
AP_INTERFACE=wlan0          # Built-in Wi-Fi — used as Access Point
INET_INTERFACE=wlan1        # Alpha USB adapter — used as internet client

AP_IP=192.168.4.1
AP_SUBNET=192.168.4.0/24
AP_DHCP_START=192.168.4.100
AP_DHCP_END=192.168.4.200

AP_DEFAULT_SSID=SUDO-Pi
AP_DEFAULT_PASSWORD=sudopi2024
AP_CHANNEL=6
AP_COUNTRY_CODE=US          # ISO 3166-1 alpha-2 country code

# ─── Config file paths (do not change unless you move them) ──────────────────
HOSTAPD_CONF_PATH=/etc/hostapd/hostapd.conf
DNSMASQ_CONF_PATH=/etc/dnsmasq.conf

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
LOG_DIR=/var/log/sudo-pi
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=200/minute

# ─── Real-time Updates ───────────────────────────────────────────────────────
SYSTEM_METRICS_INTERVAL=2.0     # seconds between WebSocket metric broadcasts
WS_HEARTBEAT_INTERVAL=30.0
WS_HEARTBEAT_TIMEOUT=60.0

# ─── File Upload ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
